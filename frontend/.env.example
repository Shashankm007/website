# ============================================================================
# Frontend (Next.js) environment. Copy to frontend/.env.local for local dev.
# NEXT_PUBLIC_* are inlined into the browser bundle at build time.
# ============================================================================

# Public API base URL used by the browser
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side base URL (used inside the Docker network; falls back to NEXT_PUBLIC_API_URL)
API_INTERNAL_URL=http://localhost:4000

# Razorpay key id (safe to expose; the key secret stays on the backend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx

# Canonical site URL (for metadata / OpenGraph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# WhatsApp click-to-chat number (digits only, with country code)
NEXT_PUBLIC_WHATSAPP_NUMBER=917017109861
