# ============================================================================
# Backend (NestJS) environment. Copy to backend/.env for local `npm run start:dev`.
# When running via docker-compose these are injected from the root .env.
# ============================================================================

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# Postgres connection string (Prisma)
DATABASE_URL=postgresql://forge3d:forge3d@localhost:5432/forge3d?schema=public

# Redis (used for throttler storage + caching). Optional in dev.
REDIS_URL=redis://localhost:6379

# --- JWT --------------------------------------------------------------------
# Generate: openssl rand -base64 48
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=900s
JWT_REFRESH_TTL=7d

# --- Cookies / crypto -------------------------------------------------------
COOKIE_SECRET=dev-cookie-secret-change-me
ENCRYPTION_KEY=                       # base64 32 bytes: openssl rand -base64 32

# --- Razorpay ---------------------------------------------------------------
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# --- SMTP -------------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="HashTag Creations <no-reply@hashtagcreations.in>"

# --- S3 / R2 ----------------------------------------------------------------
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=forge3d-assets
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=http://localhost:9000/forge3d-assets

# --- Google OAuth (optional) ------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# --- Shiprocket (shipping / fulfilment) -------------------------------------
# Create an API user in the Shiprocket dashboard (Settings → API) and use those creds.
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_LOCATION=Primary          # pickup location nickname from your Shiprocket account
SHIPROCKET_CHANNEL_ID=                       # optional custom channel id
SHIPROCKET_WEBHOOK_TOKEN=                    # token set in Shiprocket webhook config (sent as x-api-key)

# --- Chatbot (optional open-source LLM) -------------------------------------
# Leave blank to use the built-in rule-based FAQ bot. Point at any OpenAI-compatible
# endpoint serving an open-source model (Ollama / Groq / Together / HuggingFace).
CHATBOT_API_URL=                             # e.g. http://localhost:11434/v1 (Ollama) — chat completions
CHATBOT_API_KEY=                             # if the endpoint needs one
CHATBOT_MODEL=                               # e.g. llama3.1
# RAG embeddings endpoint (OpenAI-compatible). Blank = built-in local embedder.
CHATBOT_EMBED_URL=                           # e.g. http://localhost:11434/v1
CHATBOT_EMBED_MODEL=                         # e.g. nomic-embed-text

# Seed admin password used by prisma/seed.ts
SEED_ADMIN_PASSWORD=Admin123!
